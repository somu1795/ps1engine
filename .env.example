# ============================================================
# PS1 Engine Core Environment Config (.env) 
# These variables are consumed by docker-compose.yml for
# bind mounts and Traefik routing. NOT loaded by main.py directly.
# ============================================================

# --- DuckStation Image Version ---
# Pin to a specific linuxserver/duckstation image tag for reproducible builds.
# Use 'latest' to always pull the newest upstream image on rebuild.
# Find available tags: https://hub.docker.com/r/linuxserver/duckstation/tags
DUCKSTATION_VERSION=latest

# --- Domain Routing ---
# The domain name for Local Area Network access
DOMAIN_LOCAL=ps1.lan

# The domain name for Remote WAN access via Traefik
# Also read by main.py as DOMAIN (via docker env_file injection)
DOMAIN_REMOTE=ps1.yourdomain.com

# --- Host Directory Bind Mounts ---
# Absolute paths on your HOST system where files are located.

# PlayStation 1 ROM directory (.zip files)
HOST_ROM_DIR=/path/to/ROMs/PSX

# Super Nintendo ROM directory (.zip files)
HOST_SNES_ROM_DIR=/path/to/ROMs/SNES

# Game Boy Advance ROM directory (.zip files)
HOST_GBA_ROM_DIR=/path/to/ROMs/GBA

# PlayStation 1 BIOS directory (.bin files)
HOST_BIOS_DIR=/path/to/ROMs/BIOS

# Temporary extraction directory for unzipping PS1 games
HOST_CACHE_DIR=/tmp/ps1cache
