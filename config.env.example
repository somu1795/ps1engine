# ============================================================
# PS1 Engine Configuration (.config.env)
# All settings in one place. Restart services to apply changes.
# ============================================================

# --- Emulator (DuckStation) ---

# Resolution Scale: 1 (Native 240p), 2 (480p), 3 (720p), 4 (960p)
# This acts as a 'Profile' setting:
# - Level 1: Uses Software renderer (Max efficiency, native visuals)
# - Level 2-4: Uses Vulkan renderer (Upscaled, auto-tuned for quality)
RESOLUTION_SCALE=1
# CPU cores to allocate per session (e.g. 2 for 2 cores)
CPUS_PER_SESSION=2
# Memory limit per session (e.g. '2g', '512m')
MEM_LIMIT_PER_SESSION=2g

# Audio Backend: Cubeb, PulseAudio, ALSA, Null
AUDIO_BACKEND=Cubeb

# --- Streaming (Selkies/KasmVNC) ---

# Video bitrate in kbps (e.g. 2000 = 2mbps, 1000 = 1mbps)
STREAM_BITRATE=2000

# Max FPS sent to client (30 saves bandwidth, 60 is smoother)
STREAM_FRAMERATE=30

# Encoder quality (1-100, lower = less bandwidth, higher = sharper)
STREAM_QUALITY=50

# --- System ---

# Show FPS counters in emulator
SHOW_FPS=false

# Debug Mode: mount full ROM library instead of single game
ENABLE_DEBUG_MODE=false

# --- ROM Cache ---
# Max disk space for extracted ROM cache in MB (0 = disabled)
ROM_CACHE_MAX_MB=5000

# --- Safety Caps ---
# Max host CPU load (%) before blocking new sessions
MAX_HOST_CPU_PERCENT=90
# Max host RAM usage (%) before blocking new sessions
MAX_HOST_MEM_PERCENT=90
# Rate limit: Max new session requests per user per minute
RATE_LIMIT_SESSIONS_PER_MIN=3

# --- Watchdog (Session Cleanup) ---
# How long a session can be idle (no users) before cleanup (in minutes)
IDLE_TIMEOUT_MINS=30

# --- Infrastructure ---
# Internal Docker network name
NETWORK_NAME=emulator-net

# Image name for DuckStation containers
IMAGE_NAME=custom-duckstation
